<%= render "layouts/auth_layout", title: "ユーザー編集" do %>

  <%= form_with model: @user do |f| %>
    <% if @user.errors.any? %>
    <div id="error_explanation">
      <h2>
        <%= @user.errors.count %>件のエラーが発生したため、更新できませんでした。
      </h2>

      <ul>
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4"> 
    <%= f.label :profile_image, "プロフィール画像", class: "form-label d-block" %>
    <%= f.file_field :profile_image, class: "form-control"  %>
  </div>

  <div class="mb-4">
    <%= f.label :name, "名前", class: "form-label" %><br>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-4">
    <%= f.label :email_address, "メールアドレス", class: "form-label" %><br>
    <%= f.email_field :email_address, class: "form-control" %>
  </div>

  <div class="mb-4">
    <%= f.label :introduction, "自己紹介", class: "form-label" %><br>
    <%= f.text_area :introduction, class: "form-control" %>
  </div>

  <div class="mb-4">
    <%= f.submit "更新する", class: "btn btn-success" %>
  </div>
  <% end %>
<% end %>