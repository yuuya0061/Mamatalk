<%= render "layouts/auth_layout", title: "新規登録" do %>

<%= form_with model: @user do |f| %>
  <% if @user.errors.any? %>
  <div id="error_explanation">
    <h2>
      <%= @user.errors.count %>件のエラーが発生したため、登録できませんでした。
    </h2>

    <ul>
      <% @user.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

  <div class="mb-4">
    <%= f.label :ユーザー名, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", autofocus: true %>
  </div>

  <div class="mb-4">
   <%= f.label :メールアドレス, class: "form-label" %>
   <%= f.email_field :email_address, class: "form-control" %>
  </div>

  <diV class="mb-4">
   <%= f.label :パスワード, class: "form-label" %>
   <%= f.password_field :password, class: "form-control",
        minlength: 6,
        placeholder: "6文字以上で入力してください" %>
  </div>

  <div class="mb-4">
   <%= f.label :パスワード確認, class: "form-label" %>
   <%= f.password_field :password_confirmation, class: "form-control" %>
  </div>

  <div class="mb-4">
   <%= f.submit "新規登録", class: "btn btn-success" %>
  </div>

  <% end %>

  <p> すでにアカウントをお持ちの方は
     <%= link_to "ログイン", log_in_path %>
  </p>

<% end %>