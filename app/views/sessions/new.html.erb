<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
<%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>

<%= render "layouts/auth_layout", title: "ログイン" do %>
<%= form_with url: session_path do |f| %>
 <div class="mb-4">
  <%= f.label :email_address, "メールアドレス", class: "form-label" %>
  <%= f.email_field :email_address, class: "form-control",
      required: true, 
      autofocus: true, 
      autocomplete: "username", 
      placeholder: "メールアドレス", 
      value: params[:email_address] %>
 </div>

 <div class="mb-4">
  <%= f.label :password, "パスワード", class: "form-label" %>
  <%= f.password_field :password,
  class: "form-control", 
  required: true, 
  autocomplete: "current-password", 
  placeholder: "パスワード", maxlength: 50 %>
 </div>
<div class="d-grid">
  <%= f.submit "ログイン", class: "btn btn-primary" %>
</div>

<% end %>
<br>

<%= link_to "パスワードをお忘れですか?", new_password_path %>
<% end %>