<%= render "layouts/auth_layout", title: "投稿詳細" do %>

    <h3><%= @post.title %></h3>

    <p><%= @post.body %> </p>
    
    <%= image_tag @post.get_image, width: 200 %>
    
    <p>ユーザーネーム:<%= @post.user.name %></p>

    <p>投稿日：<%= @post.created_at.strftime('%Y/%m/%d') %></p>
    
  <% if @post.user == Current.user %>
  <%= link_to "編集", edit_post_path(@post) %>
  <%= link_to "削除", post_path(@post), data: {
                    turbo_method: :delete,
                    turbo_confirm: "本当に消しますか?"} %>
  <% end %>
  <%= link_to "一覧に戻る", posts_path %>
<% end %>


