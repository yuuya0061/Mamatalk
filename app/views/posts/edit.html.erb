<div>
  <h1> 編集 </h1>
</div>

<%= form_with model: @post do |f| %>
  <% if @post.errors.any? %>
  <div id="error_explanation">
    <h2>
      <%= @post.errors.count %>件のエラーが発生したため、更新できませんでした。
    </h2>

    <ul>
      <% @post.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

  <div>
    <%= label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= label :body, "本文" %><br>
    <%= f.text_area :body %>
  </div>

  <div>
    <%- label :image, "画像" %><br>
    <%= f.file_field :image, accept: "image/*" %>
  </div>

  <div>
   <%= f.submit "更新する" %>
  </div>

<% end %>