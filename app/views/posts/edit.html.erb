<%= render "layouts/auth_layout", title: "投稿編集" do %>
  <%= form_with model: @post do |f| %>
    <% if @post.errors.any? %>
    <div id="error_explanation">
      <h2>
        <%= @post.errors.count %>件のエラーが発生したため、更新できませんでした。
      </h2>

      <ul>
        <% @post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

    <div class="mb-4">
      <%= f.label :title, "タイトル", class: "form-label" %>
      <%= f.text_field :title, class: "form-control" %>
    </div>

    <div class="mb-4">
      <%= f.label :body, "本文", class: "form-label"%>
      <%= f.text_area :body, rows: 8, class: "form-control" %>
    </div>

    <div class="mb-4">
      <%- f.label :image, "画像", class: "form-label d-block" %>
      <%= f.file_field :image, accept: "image/*", class: "form-control"  %>
    </div>

    <div class="mb-4">
    <%= f.submit "更新する", class: "btn btn-success" %>
    </div>

  <% end %>
<% end %>