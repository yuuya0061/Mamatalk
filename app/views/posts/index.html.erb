<%= render "layouts/auth_layout", title: "投稿一覧" do %>
  <% @posts.each do |post| %>
    <h3><%= link_to post.title, post_path(post) %></h3>


    <p><%= post.body %> </p>
    
    <%= image_tag post.get_image, width: 200 %>
    
    <p>ユーザーネーム:<%= link_to post.user.name, user_path(post.user.id) %></p>

  <% end %>
<% end %>

